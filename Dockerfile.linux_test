# Use Ubuntu 22.04 as a base (similar to ubuntu-latest)
FROM ubuntu:22.04

# Prevent interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install basic dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    python3 \
    python3-pip \
    sudo \
    gnupg \
    software-properties-common \
    && rm -rf /var/lib/apt/lists/*

# Add .NET 10 repository and install
RUN wget https://dot.net/v1/dotnet-install.sh -O dotnet-install.sh \
    && chmod +x dotnet-install.sh \
    && ./dotnet-install.sh --channel 10.0 --install-dir /usr/share/dotnet \
    && ln -s /usr/share/dotnet/dotnet /usr/bin/dotnet

# Enable 32-bit architecture for Wine
RUN dpkg --add-architecture i386 && apt-get update && apt-get install -y \
    wine \
    wine64 \
    wine32:i386 \
    winetricks \
    xvfb \
    libfontconfig1 \
    libfreetype6 \
    libsdl2-2.0-0 \
    libdbus-1-3 \
    libdbus-1-3:i386 \
    libopenal1 \
    libhiredis-dev \
    && rm -rf /var/lib/apt/lists/*

# Setup Wine environment
ENV WINEARCH=win64
ENV WINEPREFIX=/root/.wine
RUN xvfb-run wineboot --init && xvfb-run winetricks -q d3dcompiler_47

# Set working directory
WORKDIR /app

# Copy the project
COPY . .

# Set environment variables for MGCB
ENV MGFXC_WINE_PATH=/root/.wine
ENV WINEDEBUG=-all
ENV PATH="$PATH:/root/.dotnet/tools"

# Default command: build and run health check
CMD ["/bin/bash", "-c", "cd src/IncriElemental.Desktop && dotnet tool restore && cd ../.. && python3 scripts/download_font.py && dotnet restore && xvfb-run dotnet build IncriElemental.slnx --no-restore && python3 scripts/check_health.py --skip-tests --skip-linux-build"]
